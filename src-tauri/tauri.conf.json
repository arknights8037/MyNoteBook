{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "myNoteBook",
  "version": "0.1.0",
  "identifier": "com.local.mynotebook",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "myNoteBook",
        "width": 1200,
        "height": 820,
        "minWidth": 900,
        "minHeight": 620,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:editor.db"]
    }
  }
}
